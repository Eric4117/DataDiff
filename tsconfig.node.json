{
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["electron-vite/node", "node"],
    "paths": {}
  },
  "include": ["electron.vite.config.*", "electron/**/*"]
}
